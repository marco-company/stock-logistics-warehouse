<odoo>

    <record model="ir.ui.view" id="stock_request_form_view">
        <field name="name">
            stock.request.form (in stock_request_purchase_request)
        </field>
        <field name="model">stock.request</field>
        <field name="inherit_id" ref="stock_request.view_stock_request_form" />

        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field
                    name="purchase_request_ids"
                    attrs="{'invisible': True}"
                    groups="purchase_request.group_purchase_request_user"
                />
                <button
                    type="object"
                    name="action_view_purchase_request"
                    class="oe_stat_button"
                    icon="fa-credit-card"
                    attrs="{'invisible': [('purchase_request_count', '=', 0)]}"
                    groups="purchase_request.group_purchase_request_user"
                >
                    <field
                        name="purchase_request_count"
                        widget="statinfo"
                        string="Purchase Request"
                    />
                </button>
            </xpath>
        </field>
    </record>
</odoo>
