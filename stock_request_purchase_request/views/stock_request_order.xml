<odoo>

    <record model="ir.ui.view" id="stock_request_order_form_view">
        <field name="name">
            stock.request.order.form (in stock_request_purchase_request)
        </field>
        <field name="model">stock.request.order</field>
        <field name="inherit_id" ref="stock_request.stock_request_order_form" />
        <field name="arch" type="xml">
            <header position="inside">
                <div name="button_box" class="oe_button_box">
                    <button
                        type="object"
                        name="action_view_purchase_request"
                        class="oe_stat_button"
                        icon="fa-credit-card"
                        groups="purchase_request.group_purchase_request_user"
                        attrs="{'invisible': [('purchase_request_count', '=', 0)]}"
                    >
                        <field
                            name="purchase_request_count"
                            widget="statinfo"
                            string="Purchase Requests"
                        />
                    </button>
                </div>
            </header>
        </field>
    </record>

</odoo>
